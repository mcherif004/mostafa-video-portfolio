generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectFormat {
  VERTICAL
  HORIZONTAL
}

model Project {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String?
  videoUrl     String
  thumbnailUrl String?
  format       ProjectFormat
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([format])
}

model Service {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  pricingPlans PricingPlan[]
}

model PricingPlan {
  id          String   @id @default(cuid())
  serviceId   String
  name        String
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("EUR")
  description String?
  features    Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  contact   String?
  message   String
  source    String?  @default("web")
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
